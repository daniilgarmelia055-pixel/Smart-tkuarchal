// 1. НАВИГАЦИЯ МЕЖДУ СТРАНИЦАМИ
function showPage(id) {
  document.querySelectorAll('main, .page').forEach(p => p.classList.add('hidden'));
  const target = document.getElementById(id);
  if (target) {
    target.classList.remove('hidden');
    // Обновляем данные при переходе
    if(id === 'feed') renderNews();
    if(id === 'tourism') renderTourism();
    if(id === 'sports') renderSports();
  }
  window.scrollTo(0,0);
}

// 2. ЗАГРУЗКА ПОГОДЫ (ТКУАРЧАЛ)
async function loadWeather() {
  try {
    const res = await fetch('https://api.open-meteo.com');
    const data = await res.json();
    const temp = Math.round(data.current_weather.temperature);
    document.getElementById('temp').innerText = temp + '°C';
  } catch(e) { 
    document.getElementById('temp').innerText = '??°C'; 
  }
}

// 3. МОДАЛЬНЫЕ ОКНА (ТАКСИ, РЕЙСЫ)
function openModal(type) {
  const body = document.getElementById('modal-body');
  const title = document.getElementById('modal-title');
  const overlay = document.getElementById('modal-overlay');
  const box = document.getElementById('modal-box');
  
  if (type === 'taxi') {
    title.innerText = 'ВЫЗОВ ТАКСИ 🚕';
    body.innerHTML = 
      <div class="space-y-4">
        <a href="tel:+79407260260" class="flex justify-between items-center p-7 bg-yellow-50 rounded-[35px] border border-yellow-200 active:scale-95 transition shadow-sm">
          <span class="font-black text-yellow-900 text-xl tracking-tighter uppercase">+7 940 726-02-60</span>
          <span class="text-3xl">📞</span>
        </a>
      </div>;
  }

  if (type === 'transport') {
    title.innerText = 'РЕЙСЫ 🚌';
    body.innerHTML = 
      <div class="space-y-4">
        <div class="p-7 bg-blue-50 rounded-[35px] border border-blue-100 shadow-sm">
          <b class="text-blue-900 block text-lg uppercase font-black italic">Сухум — 300 ₽</b>
          <p class="text-xs text-blue-600 font-bold mt-2">08:00, 09:30, 11:30, 14:00, 16:30</p>
        </div>
      </div>;
  }

  overlay.classList.remove('hidden');
  setTimeout(() => box.classList.remove('translate-y-full'), 10);
}

function closeModal() {
  document.getElementById('modal-box').classList.add('translate-y-full');
  setTimeout(() => document.getElementById('modal-overlay').classList.add('hidden'), 300);
}

// 4. ЛОГИКА АДМИНКИ И ПРОФИЛЯ
function login() {
  const name = document.getElementById('name-in').value.trim();
  if (name) {
    document.getElementById('login-box').classList.add('hidden');
    document.getElementById('user-box').classList.remove('hidden');
    document.getElementById('u-name').innerText = name;
  }
}

function openAdmin() { document.getElementById('admin-modal').classList.remove('hidden'); }
function closeAdmin() { document.getElementById('admin-modal').classList.add('hidden'); }

// ИНИЦИАЛИЗАЦИЯ ПРИ ЗАГРУЗКЕ
window.onload = () => {
  loadWeather();
  // Если есть новости в localStorage, отрисовываем
  if(typeof renderNews === 'function') renderNews();
};