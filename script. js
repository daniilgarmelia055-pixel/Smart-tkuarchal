const APP_URL = "https://script.google.com";
let user = "admin";

async function loadWeather() {
    try {
        const res = await fetch("https://api.open-meteo.com");
        const data = await res.json();
        const t = Math.round(data.current_weather.temperature);
        document.getElementById('temp').innerText = (t > 0 ? '+' : '') + t + "°C";
    } catch (e) { document.getElementById('temp').innerText = "??°C"; }
}

async function initApp(tab = 'tourism') {
    document.getElementById('u-name').innerText = user;
    document.getElementById('header-user').innerText = user;
    if(user.toLowerCase() === 'admin') { document.getElementById('admin-btn').classList.remove('hidden'); }

    const container = document.getElementById('content-list');
    container.innerHTML = '<div class="loader">Синхронизация...</div>';
    try {
        const res = await fetch(${APP_URL}?type=${encodeURIComponent(tab)});
        const data = await res.json();
        container.innerHTML = '';
        if (data && data.length > 0) {
            data.forEach(item => {
                const v = Object.values(item);
                container.innerHTML += <div class="content-item"><h4>${v}</h4><p>${v}</p></div>;
            });
        } else { container.innerHTML = '<div class="loader">Пусто</div>'; }
    } catch (e) { container.innerHTML = '<div class="loader">Ошибка связи</div>'; }
}

function openSOS() { initApp('Службы'); }

window.onload = () => {
    loadWeather();
    initApp('tourism');
};